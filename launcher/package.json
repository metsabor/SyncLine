{
  "name": "syncline",
  "version": "1.0.0",
  "description": "Быстрый и стильный мессенджер для передачи файлов, ссылок и сообщений",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac --x64",
    "build:linux": "electron-builder --linux --x64"
  },
  "keywords": [
    "syncline",
    "messenger",
    "file-transfer",
    "electron",
    "glassmorphism"
  ],
  "author": "SyncLine Team",
  "license": "MIT",
  "build": {
    "appId": "com.syncline.app",
    "productName": "SyncLine",
    "directories": {
      "output": "build",
      "buildResources": "buildResources"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "src/assets",
        "to": "assets"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "src/assets/images/icon.ico",
      "publisherName": "SyncLine Team",
      "certificateFile": "",
      "certificatePassword": ""
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": "dmg",
      "icon": "src/assets/images/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "src/assets/images/icon.png"
    }
  },
  "devDependencies": {
    "electron": "^28.2.0",
    "electron-builder": "^24.9.0",
    "electron-packager": "^17.1.2"
  },
  "dependencies": {
    "livekit-client": "^2.0.0"
  }
}
